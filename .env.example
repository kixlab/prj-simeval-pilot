# OpenAI agent runtime. Keep the API key server-side.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1-mini

# Human-only deployments should keep both flags disabled.
# Set both values to true for agent research/development sessions.
VITE_ENABLE_AGENT_MODE=false
ENABLE_AGENT_API=false

# Preferred: absolute path to a Google Cloud service-account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=

# Optional Google Speech-to-Text settings.
GOOGLE_STT_LANGUAGE_CODE=ko-KR
GOOGLE_STT_ALTERNATIVE_LANGUAGE_CODES=en-US
GOOGLE_STT_MODEL=latest_long
